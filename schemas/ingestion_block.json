{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "IngestionBlock",
    "description": "Output dello Stadio A (TextIngester) — un blocco di testo estratto",
    "type": "object",
    "required": [
        "job_id",
        "book_id",
        "chapter_id",
        "block_id",
        "block_text",
        "word_count",
        "block_index",
        "total_blocks_in_chapter"
    ],
    "properties": {
        "job_id": {
            "type": "string",
            "format": "uuid"
        },
        "book_id": {
            "type": "string"
        },
        "chapter_id": {
            "type": "string"
        },
        "chapter_number": {
            "type": "integer",
            "minimum": 1
        },
        "chapter_title": {
            "type": "string"
        },
        "block_id": {
            "type": "string"
        },
        "block_text": {
            "type": "string",
            "minLength": 1
        },
        "word_count": {
            "type": "integer",
            "minimum": 1
        },
        "block_index": {
            "type": "integer",
            "minimum": 0
        },
        "total_blocks_in_chapter": {
            "type": "integer",
            "minimum": 1
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        }
    }
}