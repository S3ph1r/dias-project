# DIAS gitignore

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Audio output (generated, large files)
storage/
*.wav
*.mp3
*.flac

# Models (too large for git)
models/

# State (runtime)
state/*.json

# Secrets
secrets/
*.key

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker volumes
docker/volumes/

# Data (runtime, too large/private)
data/
outputs/
voices/
*.log

# Temp
*.tmp
*.bak

# Node.js & SvelteKit (Added for Dashboard)
node_modules/
src/dashboard/node_modules/
src/dashboard/.svelte-kit/
src/dashboard/build/
src/dashboard/dist/
.env.*
!.env.template
