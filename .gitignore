# DIAS Gitignore - Pulizia e Sicurezza
# Progetto: Distributed Immersive Audiobook System

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Configurazione Locale (Sostituire con template per Git)
config/*.local.yaml
*.env

# Audio Output (Dati di produzione pesanti)
storage/
data/
outputs/
voices/
*.wav
*.mp3
*.flac

# Analisi e Test
analysis/
tests/*.json
!tests/__init__.py
*.log
*.tmp
*.bak
*.pid

# Documentazione Archivio e Backup
docs/backups/
docs/archive/cleanup_*/

# Modelli e Pesi AI
models/

# Stato Runtime
state/*.json

# Credenziali e Chiavi
secrets/
*.key
*.pem
*.pub

# IDE e OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Docker
docker/volumes/

# Node.js & SvelteKit
node_modules/
src/dashboard/node_modules/
src/dashboard/.svelte-kit/
src/dashboard/build/
src/dashboard/dist/
.env.*
!.env.template
